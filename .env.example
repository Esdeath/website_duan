# 复制为 .env 后填入真实值（.env 已被 .gitignore 忽略）

# 站点 URL —— 影响 sitemap.xml / robots.txt / JSON-LD
NUXT_PUBLIC_SITE_URL=https://your-domain
# Twikoo 评论后端地址（Cloudflare Worker URL）；为空则文章页不渲染评论区
NUXT_PUBLIC_COMMENT_ENV_ID=https://twikoo-cloudflare.xxx.workers.dev

# 部署：代码 push 到 GitHub 后由 Cloudflare Pages 自动构建上线（见 scripts/deploy.sh）
# 可选，默认推到名为 github 的远程；改名时覆盖即可
# DEPLOY_GIT_REMOTE=github
